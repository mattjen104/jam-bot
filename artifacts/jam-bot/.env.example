# ============================================================================
# Spotify (developer.spotify.com/dashboard)
# ============================================================================
# Create an app, set redirect URI to http://127.0.0.1:8888/callback
# (used only by the one-time `pnpm run spotify:auth` CLI).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Get this by running: pnpm run spotify:auth
SPOTIFY_REFRESH_TOKEN=
# The librespot device name to transfer playback to on startup.
# Must match the `--name` flag in your librespot systemd unit.
SPOTIFY_DEVICE_NAME=Jam Host

# ============================================================================
# Slack (api.slack.com/apps)
# ============================================================================
# Bot User OAuth Token, starts with xoxb-
SLACK_BOT_TOKEN=
# App-Level Token for Socket Mode, starts with xapp-
SLACK_APP_TOKEN=
# Signing secret from Basic Information
SLACK_SIGNING_SECRET=
# Channel ID where the bot listens and posts (e.g. C0123456789).
# Right-click channel name in Slack -> View channel details -> bottom of pane.
SLACK_CHANNEL_ID=

# ============================================================================
# OpenRouter (openrouter.ai/keys)
# ============================================================================
OPENROUTER_API_KEY=
# Any OpenRouter model slug, e.g. anthropic/claude-3.5-sonnet,
# openai/gpt-4o-mini, meta-llama/llama-3.3-70b-instruct
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# ============================================================================
# Bot internals
# ============================================================================
# How often (ms) to poll Spotify for the currently playing track.
NOW_PLAYING_POLL_MS=5000
# SQLite database path (created on first run).
DATABASE_PATH=./data/jam.db
# History rows to include as LLM context.
LLM_HISTORY_WINDOW=25
# Log level: debug | info | warn | error
LOG_LEVEL=info
# Distinct users that must press the "Vote skip" button on the now-playing
# card before the bot skips the current track.
SKIP_VOTE_THRESHOLD=3
# Rolling window (seconds) within which those votes must arrive. Older
# votes are pruned before each tally.
SKIP_VOTE_WINDOW_SECONDS=300
# Soft cap on how many `/play` requests a single user can make per rolling
# hour. Over this they get an ephemeral "slow down" reply. Also caps how
# often a single user can fire off a `/memory play me a set...` request.
MAX_PLAYS_PER_USER_PER_HOUR=5

# ============================================================================
# Jam Memory (Wrapped / DNA / Compat / Memory)
# ============================================================================
# Whether the auto-weekly Wrapped post is enabled. /wrapped on demand always
# works; this only controls the scheduled post.
JAM_ENABLE_WEEKLY_WRAPPED=true
# When the auto-weekly post fires, in UTC. Format: "<Day> HH:MM" where Day is
# Sun/Mon/Tue/Wed/Thu/Fri/Sat. The scheduler checks every 30s and only fires
# once per day.
JAM_WRAPPED_SCHEDULE=Sun 20:00
# How many days back /wrapped and the auto-Wrapped post look.
JAM_WRAPPED_LOOKBACK_DAYS=7
# Cap on how many tracks `/memory play me a set...` will queue at once.
JAM_MEMORY_MAX_QUEUE=10

# Days the "Now playing" card is allowed to post (UTC, 0=Sun..6=Sat,
# comma-separated). Default = Friday only, so friends only get pinged
# with track-change cards on Fridays. Music still plays and is logged
# to history every day. Set "0,1,2,3,4,5,6" to post every day.
JAM_NOWPLAYING_DAYS=5

# Slack user ID (e.g. U01ABC...) to receive bot output as DMs while
# /quiet mode is on. When set, slash command replies and @mention
# answers DM this user instead of posting in-channel — so testing
# produces a real DM thread you can scroll back through. If unset,
# quiet mode falls back to ephemeral messages to the slash caller.
JAM_QUIET_DM_USER=

# ============================================================================
# Spotify Jam (optional, advanced)
# ============================================================================
# Spotify hasn't published a public API for starting a Jam (social listening
# session). The bot uses an undocumented internal endpoint that requires an
# "internal" access token derived from the `sp_dc` browser cookie.
#
# IMPORTANT: Spotify blocks the cookie -> token exchange from datacenter
# IPs (DigitalOcean, AWS, etc). On a cloud droplet, SPOTIFY_SP_DC alone
# WILL NOT WORK — you'll see 403 "URL Blocked" in the logs and `/jam`
# will fall back to manual instructions.
#
# Two ways to make /jam work programmatically:
#
# Option A (RECOMMENDED for cloud droplets): run tools/spotify-token-relay
# on a home computer / Pi. The cookie stays on the home machine; the
# droplet calls the relay over a Cloudflare tunnel. See
# tools/spotify-token-relay/README.md for full setup.
SPOTIFY_TOKEN_RELAY_URL=
SPOTIFY_TOKEN_RELAY_SECRET=
#
# Option B (only works on a residential IP — laptop, home server, etc):
# paste the host account's sp_dc cookie directly. Get it from
# open.spotify.com -> DevTools -> Application -> Cookies -> sp_dc.
# Leave blank if you're using the relay above.
SPOTIFY_SP_DC=
