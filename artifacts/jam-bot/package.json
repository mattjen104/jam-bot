{
  "name": "@workspace/jam-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-hosted Slack bot that runs a permanent Spotify Jam from a DigitalOcean droplet.",
  "scripts": {
    "dev": "tsx watch ./src/index.ts",
    "start": "node ./dist/index.cjs",
    "start:tsx": "tsx ./src/index.ts",
    "build": "tsx ./build.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "spotify:auth": "tsx ./src/spotify/auth-cli.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@slack/bolt": "^4.6.0",
    "@slack/types": "^2.20.1",
    "@workspace/song-enrichment": "workspace:*",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.5",
    "spotify-web-api-node": "^5.0.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "catalog:",
    "@types/spotify-web-api-node": "^5.0.11",
    "esbuild": "^0.27.3",
    "tsx": "catalog:",
    "typescript": "^5.9.0",
    "vitest": "^4.1.5"
  }
}
